// Schéma Prisma — base Postgres pour l'authentification par comptes.
//   Générer le client : npm run db:generate
//   Appliquer le schéma : npm run db:migrate   (nécessite la base démarrée)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())
}
